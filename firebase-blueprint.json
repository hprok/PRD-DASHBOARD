{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A PRD project for a specific application",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the application" },
        "description": { "type": "string", "description": "Brief description of the app" },
        "createdAt": { "type": "string", "format": "date-time" },
        "currentVersionId": { "type": "string", "description": "ID of the latest version" }
      },
      "required": ["name", "createdAt"]
    },
    "PRDVersion": {
      "title": "PRD Version",
      "description": "A specific version of the PRD data for a project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "notes": { "type": "string", "description": "Reason for this version" },
        "createdAt": { "type": "string", "format": "date-time" },
        "data": {
          "type": "object",
          "properties": {
            "useCases": { "type": "array" },
            "workflows": { "type": "array" },
            "screens": { "type": "array" },
            "apiEndpoints": { "type": "array" },
            "businessRules": { "type": "array" },
            "permissions": { "type": "array" },
            "traceability": { "type": "array" },
            "validation": { "type": "array" }
          }
        }
      },
      "required": ["projectId", "createdAt", "data"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of PRD projects"
    },
    "/projects/{projectId}/versions/{versionId}": {
      "schema": "PRDVersion",
      "description": "Versions of PRD for a specific project"
    }
  }
}
